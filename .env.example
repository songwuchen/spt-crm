# ============================================
# SPT-CRM Production Environment Variables
# Copy to .env and fill in actual values
# ============================================

# ---------- Database ----------
POSTGRES_PASSWORD=change-me-use-strong-password

# ---------- JWT ----------
JWT_SECRET_KEY=change-me-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ---------- CORS ----------
# 三个域名共用同一端口(8410)，按域名区分 web 端 / 移动端 / 平台管理端
CORS_ORIGINS=https://wm.fourier.net.cn:8410,https://link.fourier.net.cn:8410,https://wm-platform.fourier.net.cn:8410

# ---------- File Upload ----------
UPLOAD_DIR=uploads

# ---------- AI Provider ----------
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=gpt-4o
AI_BASE_URL=https://api.openai.com/v1

# ---------- Encryption ----------
ENCRYPTION_KEY=
