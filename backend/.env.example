# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/spt_crm

# JWT Authentication
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# File upload directory
UPLOAD_DIR=uploads

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5175,http://localhost:3000

# AI Provider: mock | openai | azure
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=gpt-4o
AI_BASE_URL=https://api.openai.com/v1

# Encryption key for sensitive integration config (32+ chars recommended)
ENCRYPTION_KEY=
